<!DOCTYPE html>
<html lang="{{ site.lang or 'en' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ post.title }} - {{ site.name }}</title>
  <meta name="description" content="{{ post.summary or site.description }}">
  {% if site.favicon %}<link rel="icon" href="{{ site.favicon }}">{% endif %}
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Bungee+Shade&display=swap" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="{{ static('style.css') }}">
  
  <!-- Open Graph -->
  <meta property="og:title" content="{{ post.title }}">
  <meta property="og:description" content="{{ post.summary or site.description }}">
  <meta property="og:type" content="article">
  <meta property="og:url" content="{{ post.url }}">
</head>
<body class="post">
  <header>
    <a class="title" href="{{ site.url }}">
      <h1>{{ site.name }}</h1>
    </a>
    <nav>
      <a href="{{ site.url }}">Home</a>
      {% for nav in site.navs %}
      <a href="{{ nav.url }}">{{ nav.title }}</a>
      {% endfor %}
    </nav>
  </header>

  <main>
    <article>
      <h1 class="post-title">{{ post.title }}</h1>
      <div class="post-meta">
        <time>{{ post.date.strftime('%Y-%m-%d') }}</time>
        {% if post.tags %}
        <span class="tags">
          {% for tag in post.tags %}
          <a href="{{ tag.url }}">#{{ tag.name }}</a>
          {% endfor %}
        </span>
        {% endif %}
      </div>
      
      <div class="post-content">
        {{ post.content }}
      </div>
    </article>
    
    {% if post.prev or post.next %}
    <nav class="post-nav">
      {% if post.prev %}
      <a class="prev" href="{{ post.prev.url }}">← {{ post.prev.title }}</a>
      {% endif %}
      {% if post.next %}
      <a class="next" href="{{ post.next.url }}">{{ post.next.title }} →</a>
      {% endif %}
    </nav>
    {% endif %}
  </main>

  <footer>
    <p>Crafted with ❤️</p>
  </footer>
</body>
</html>