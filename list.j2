<!DOCTYPE html>
<html lang="{{ site.lang or 'en' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - {{ site.name }}</title>
  <meta name="description" content="{{ site.description }}">
  {% if site.favicon %}<link rel="icon" href="{{ site.favicon }}">{% endif %}
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Bungee+Shade&display=swap" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="{{ static('style.css') }}">
  
  <!-- Theme Toggle -->
  <script src="{{ static('theme.js') }}"></script>
</head>
<body class="archive">
  <header>
    <a class="title" href="{{ site.url }}">
      <h1>{{ site.name }}</h1>
    </a>
    <nav>
      <a href="{{ site.url }}">Home</a>
      {% for nav in site.navs %}
      <a href="{{ nav.url }}">{{ nav.title }}</a>
      {% endfor %}
      <a href="#" class="theme-toggle" onclick="toggleTheme(event)">☀</a>
    </nav>
  </header>

  <main>
    <h1 class="page-title">{{ title }}</h1>
    
    {% if posts %}
    <ul class="blog-posts">
      {% for post in posts %}
      <li>
        <time>{{ post.date.strftime('%Y-%m-%d') }}</time>
        <a href="{{ post.url }}">{{ post.title }}</a>
      </li>
      {% endfor %}
    </ul>
    {% endif %}
    
    {% if pagination %}
    <nav class="pagination">
      {% if pagination.prev %}
      <a href="{{ pagination.prev }}">← Previous</a>
      {% endif %}
      {% if pagination.next %}
      <a href="{{ pagination.next }}">Next →</a>
      {% endif %}
    </nav>
    {% endif %}
  </main>

  <footer>
    <p>Crafted with ❤️</p>
  </footer>
</body>
</html>